{
  "name": "tweeconversion",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "import": "tsc -p tsconfig.json && node dist/cli/import-twee.js",
    "export": "tsc -p tsconfig.json && node dist/cli/export-twee.js",
    "sync:dry": "tsc -p tsconfig.json && node dist/cli/sync.js dry",
    "sync:push": "tsc -p tsconfig.json && node dist/cli/sync.js push",
    "sync:pull": "tsc -p tsconfig.json && node dist/cli/sync.js pull",
    "sync:delete": "tsc -p tsconfig.json && node dist/cli/sync.js delete",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
